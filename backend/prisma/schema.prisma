// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FundingAgency {
  id String @id

  clientSecret String?
  clientId     String?
  data         Json    @default("{}")
}

// RIS
model Project {
  id Int @id @default(autoincrement())

  risId   String @unique
  risData Json   @default("{}")

  // the dates are obtained from RIS Data
  startDate DateTime?
  endDate   DateTime?
  status    String?

  researchInstitutions ResearchInstitution[] @relation("ProjectToResearchInstitution")

  savedTemplates   SavedTemplate[]
  externalEntities ExternalEntity[]

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model CustomFunction {
  id Int @id @default(autoincrement())

  name        String @unique
  description String @default("")
  code        String @default("")
  language    String @default("javascript")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

enum TemplateType {
  PROJECT
  APPLICATION
  AWARD
}

model Template {
  id Int @id @default(autoincrement())

  templateType TemplateType
  name         String
  description  String       @default("")
  yamlTemplate String

  createdDate    DateTime        @default(now())
  modifiedDate   DateTime        @updatedAt
  savedTemplates SavedTemplate[]
}

// The SavedTemplate is a snapshot of:
// - for a Project with a given risData
// - the Template (with a yamlTemplate)
// - and specific `settings`
//
// Saving a SavedTemplate can be done when:
// - the User through the frontend with 'refreshDiff'
// - the User through the frontend with 'upload'
// - NOT automatically with diff-sync
model SavedTemplate {
  id Int @id @default(autoincrement())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])
  risData   Json    @default("{}")

  settings Json @default("{}")

  templateId Int
  template   Template @relation(fields: [templateId], references: [id])

  diffList Json    @default("[]")
  changed  Boolean @default(false) // this is the same as `diffList != []`

  externalEntityId Int
  externalEntity   ExternalEntity @relation(fields: [externalEntityId], references: [id])

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt

  @@unique([projectId, templateId, externalEntityId])
}

model ExternalEntity {
  id Int @id @default(autoincrement())

  uuid         String?
  templateType TemplateType @default(PROJECT)

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  crisId        Int
  cris          CRIS            @relation(fields: [crisId], references: [id])
  SavedTemplate SavedTemplate[]

  @@unique([projectId, crisId, uuid, templateType])
}

model CRIS {
  id Int @id @default(autoincrement())

  name   String  @default("")
  apiUrl String  @default("")
  apiKey String? @default("")
  data   Json    @default("{}")

  researchInstitution   ResearchInstitution? @relation(fields: [researchInstitutionId], references: [id])
  researchInstitutionId Int?

  externalEntities ExternalEntity[]

  @@unique([researchInstitutionId, name])
}

model ResearchInstitution {
  id     Int     @id @default(autoincrement())
  name   String?
  domain String?
  rorId  String  @unique

  users    User[]
  cris     CRIS[]
  projects Project[] @relation("ProjectToResearchInstitution")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model User {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  username String  @unique
  password String?

  researchInstitution   ResearchInstitution? @relation(fields: [researchInstitutionId], references: [id])
  researchInstitutionId Int?

  permission String[] @default(["edit"])
}
