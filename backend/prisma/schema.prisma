// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FundingAgency {
  id String @id

  clientSecret String?
  clientId     String?
  data         Json    @default("{}")
}

// RIS
model Project {
  id Int @id @default(autoincrement())

  risId   String @unique
  risData Json   @default("{}")

  // the dates are obtained from RIS Data
  startDate DateTime?
  endDate   DateTime?
  // use the status
  status    String?

  // savedTemplate SavedTemplate[]

  // crisId   String?
  // crisUUID String?

  researchInstitutions ResearchInstitution[] @relation("ProjectToResearchInstitution")

  createdDate    DateTime        @default(now())
  modifiedDate   DateTime        @updatedAt
  // Diff         Diff[]
  savedTemplates SavedTemplate[]
}

enum TemplateType {
  PROJECT
  APPLICATION
  AWARD
}

model Template {
  id Int @id @default(autoincrement())

  templateType TemplateType
  name         String
  description  String       @default("")
  yamlTemplate String

  createdDate    DateTime        @default(now())
  modifiedDate   DateTime        @updatedAt
  // Diff         Diff[]
  savedTemplates SavedTemplate[]
}

model SavedTemplate {
  id Int @id @default(autoincrement())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])
  risData   Json    @default("{}")

  settings Json @default("{}")

  yamlTemplate String       @default("")
  templateId   Int
  template     Template     @relation(fields: [templateId], references: [id])
  templateType TemplateType @default(PROJECT)

  diff Diff[]

  createdDate DateTime @default(now())
  // it's not modifiable
}

model User {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  username String  @unique
  password String?

  researchInstitution   ResearchInstitution? @relation(fields: [researchInstitutionId], references: [id])
  researchInstitutionId Int?

  permission String[] @default(["edit"])
}

model CustomFunction {
  id Int @id @default(autoincrement())

  name        String @unique
  description String @default("")
  code        String @default("")
  language    String @default("javascript")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model Diff {
  id Int @id @default(autoincrement())

  savedTemplateId Int
  savedTemplate   SavedTemplate @relation(fields: [savedTemplateId], references: [id])

  crisId   Int
  cris     CRIS   @relation(fields: [crisId], references: [id])
  endpoint String
  method   String @default("POST")
  crisUUID String

  diffList Json    @default("[]")
  changed  Boolean @default(false)

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model ResearchInstitution {
  id     Int     @id @default(autoincrement())
  name   String?
  domain String?
  rorId  String  @unique

  users    User[]
  cris     CRIS[]
  projects Project[] @relation("ProjectToResearchInstitution")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model CRIS {
  id Int @id @default(autoincrement())

  name   String  @default("")
  apiUrl String  @default("")
  apiKey String? @default("")
  data   Json    @default("{}")

  researchInstitution   ResearchInstitution? @relation(fields: [researchInstitutionId], references: [id])
  researchInstitutionId Int?

  diffs Diff[]

  @@unique([researchInstitutionId, name])
}
