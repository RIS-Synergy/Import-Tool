// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// RIS
model Project {
  id Int @id @default(autoincrement())

  risId   String @unique
  risData Json   @default("{}")

  // the dates are obtained from RIS Data
  startDate DateTime?
  endDate   DateTime?
  // use the status
  status    String?

  savedTemplate SavedTemplate[]

  crisId   String?
  crisUUID String?

  researchInstitutions ResearchInstitution[] @relation("ProjectToResearchInstitution")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
  Diff         Diff[]
}

enum TemplateType {
  PROJECT
  APPLICATION
  AWARD
}

model Template {
  id Int @id @default(autoincrement())

  templateType TemplateType
  name         String
  description  String       @default("")
  yamlTemplate String

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
  Diff         Diff[]
}

model SavedTemplate {
  id Int @id @default(autoincrement())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  settings Json @default("{}")
  template Json @default("{}")
  saveData Json @default("{}")

  createdDate DateTime @default(now())
}

model User {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  username String  @unique
  password String?

  researchInstitution   ResearchInstitution? @relation(fields: [researchInstitutionId], references: [id])
  researchInstitutionId Int?

  permission String[] @default(["edit"])
}

model CustomFunction {
  id Int @id @default(autoincrement())

  name        String @unique
  description String @default("")
  code        String @default("")
  language    String @default("javascript")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model Diff {
  id      String  @id
  project Project @relation(fields: [id], references: [risId])

  templateId Int
  template   Template @relation(fields: [templateId], references: [id])

  length Int
  list   Json @default("[]")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model ResearchInstitution {
  id     Int     @id @default(autoincrement())
  name   String?
  domain String?
  rorId  String  @unique

  users    User[]
  cris     CRIS[]
  projects Project[] @relation("ProjectToResearchInstitution")

  createdDate  DateTime @default(now())
  modifiedDate DateTime @updatedAt
}

model CRIS {
  id Int @id @default(autoincrement())

  name   String  @default("")
  apiUrl String  @default("")
  apiKey String? @default("")
  data   Json    @default("{}")

  researchInstitution   ResearchInstitution? @relation(fields: [researchInstitutionId], references: [id])
  researchInstitutionId Int?

  @@unique([researchInstitutionId, name])
}
