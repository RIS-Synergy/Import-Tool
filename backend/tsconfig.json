{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "sourceMap": true,
        "outDir": "./dist",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ],
        "typeRoots": [
            "src/types",
            "node_modules/@types"
        ],
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
    ],
    "exclude": [
        "node_modules"
    ],
    // "ts-node": {
    //     "esm": true,
    //     "experimentalSpecifierResolution": "node"
    // }
}
