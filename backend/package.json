{
  "name": "ris-backend",
  "version": "1.0.0",
  "description": "RIS-Synergy API: Funder -> PURE interface",
  "type": "module",
  "scripts": {
    "dev": "PORT=3001 tsx watch ./src/server.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "build": "tsc",
    "docker": "tsx ./src/server.ts",
    "debug": "PORT=3001 tsx --inspect=0.0.0.0 ./src/server.ts",
    "test": "vitest --ui --open=false --api.host=0.0.0.0",
    "test:docker": "docker exec -it backend yarn vitest --ui --open=false --api.host=0.0.0.0 --coverage.enabled=true",
    "test:ci": "vitest --coverage.enabled=true",
    "test:coverage": "docker exec -it backend yarn vitest --ui --open=false --api.host=0.0.0.0 --coverage.enabled=true --coverage.reporter=text",
    "db-init": "tsx ./scripts/db-initiate.ts",
    "db-user": "tsx ./scripts/db-user.ts",
    "create-project": "tsx ./scripts/create-project.ts",
    "create-application": "tsx ./scripts/create-application.ts",
    "create-award": "tsx ./scripts/create-award.ts",
    "create-system-user": "tsx ./scripts/create-system-user.ts",
    "create-functions": "tsx ./scripts/create-functions.ts",
    "create-ri": "tsx ./scripts/create-ri.ts",
    "create-cris": "tsx ./scripts/create-cris.ts",
    "connect-project-ri": "tsx ./scripts/connect-project-ri.ts",
    "copy": "tsx ./scripts/copy-projects-from-fa.ts",
    "fa-api": "tsx ./scripts/fa-api.ts",
    "json-to-excel": "tsx ./scripts/json-to-excel.ts",
    "update-projects": "tsx ./scripts/update-projects.ts"
  },
  "keywords": [],
  "author": "Kirill Stytsenko <kirill@styts.com>",
  "private": true,
  "license": "EUPL-1.2",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "prisma": "5.20.0",
    "prompts": "^2.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite-tsconfig-paths": "3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@prisma/client": "5.20.0",
    "@types/yargs": "^17.0.33",
    "bcryptjs": "^2.4.3",
    "bluebird": "^3.7.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": ">=5.0.0-beta.1",
    "flat": "^6.0.1",
    "glob": "^11.0.0",
    "isolated-vm": "^5.0.3",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "ofetch": "^1.4.1",
    "pino": "^9.6.0",
    "pino-loki": "^2.5.0",
    "tslog": "^4.9.2",
    "tsx": "^4.20.5",
    "undici": "^7.5.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.4.3",
    "yargs": "^18.0.0"
  }
}
