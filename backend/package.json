{
  "name": "ris-backend",
  "version": "1.0.0",
  "description": "RIS-Synergy API: Funder -> PURE interface",
  "scripts": {
    "dev": "PORT=3001 nodemon --exitcrash --ignore ./tests src/server.ts",
    "build": "tsc",
    "docker": "ts-node ./src/server.ts",
    "debug": "PORT=3001 nodemon --exec node --inspect=0.0.0.0 -r ts-node/register ./src/server.ts",
    "test": "vitest --ui --open=false --api.host=0.0.0.0 --coverage.enabled=true",
    "test:docker": "docker exec -it backend yarn vitest --ui --open=false --api.host=0.0.0.0 --coverage.enabled=true",
    "test:ci": "vitest --coverage.enabled=true",
    "test:coverage": "docker exec -it backend yarn vitest --ui --open=false --api.host=0.0.0.0 --coverage.enabled=true --coverage.reporter=text",
    "db-init": "ts-node ./scripts/db-initiate.ts",
    "db-user": "ts-node ./scripts/db-user.ts",
    "create-project": "ts-node ./scripts/create-project.ts",
    "create-application": "ts-node ./scripts/create-application.ts",
    "create-award": "ts-node ./scripts/create-award.ts",
    "create-system-user": "ts-node ./scripts/create-system-user.ts",
    "create-functions": "ts-node ./scripts/create-functions.ts",
    "copy": "ts-node ./scripts/copy-projects-from-fa.ts",
    "fa-api": "ts-node ./scripts/fa-api.ts",
    "json-to-excel": "ts-node ./scripts/json-to-excel.ts"
  },
  "keywords": [],
  "author": "Kirill Stytsenko <kirill@styts.com>",
  "private": true,
  "license": "EUPL-1.2",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@vitest/coverage-istanbul": "^2.1.8",
    "@vitest/ui": "2.1.3",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.0.0",
    "prisma": "5.20.0",
    "prompts": "^2.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "2.1.3"
  },
  "dependencies": {
    "@prisma/client": "5.20.0",
    "bcryptjs": "^2.4.3",
    "bluebird": "^3.7.2",
    "dotenv": "^16.4.5",
    "express": ">=5.0.0-beta.1",
    "flat": "^6.0.1",
    "glob": "^11.0.0",
    "isolated-vm": "^5.0.3",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "ofetch": "^1.4.1",
    "pino": "^9.6.0",
    "pino-loki": "^2.5.0",
    "tslog": "^4.9.2",
    "undici": "^7.5.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.4.3"
  }
}
