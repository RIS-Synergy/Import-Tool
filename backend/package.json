{
  "name": "ris-api",
  "version": "1.0.0",
  "description": "RIS-Synergy API: Funder -> PURE interface",
  "scripts": {
    "dev": "nodemon --ignore ./tests src/server.ts",
    "debug": "nodemon --exec node --inspect-brk=0.0.0.0 -r ts-node/register ./src/server.ts",
    "test": "vitest",
    "test:docker": "vitest --ui --open=false --api.host=0.0.0.0",
    "db-init": "ts-node ./scripts/db-initiate.ts",
    "create-project": "ts-node ./scripts/create-project.ts",
    "create-application": "ts-node ./scripts/create-application.ts",
    "create-award": "ts-node ./scripts/create-award.ts",
    "create-system-user": "ts-node ./scripts/create-system-user.ts",
    "copy": "ts-node ./scripts/copy-projects-from-fa.ts"
  },
  "keywords": [],
  "author": "Kirill Stytsenko <kirill@styts.com>",
  "license": "Unlicensed",
  "private": true,
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@vitest/ui": "2.1.3",
    "nodemon": "^3.1.0",
    "prisma": "5.20.0",
    "prompts": "^2.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "2.1.3"
  },
  "dependencies": {
    "@prisma/client": "5.20.0",
    "bluebird": "^3.7.2",
    "dotenv": "^16.4.5",
    "express": ">=5.0.0-beta.1",
    "flat": "^6.0.1",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "ofetch": "^1.3.4",
    "tslog": "^4.9.2",
    "yaml": "^2.4.3"
  }
