{
  "name": "ris-frontend",
  "version": "1.0.0",
  "private": true,
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --dotenv .env.dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "refactor-helper": "node ./scripts/refactor-helper.js",
    "playwright:test": "NODE_ENV=development npx playwright test -c ./tests/playwright.config.ts --workers=1 --project=dev",
    "playwright:ui": "NODE_ENV=development npx playwright test -c ./tests/playwright.config.ts --ui --project=dev",
    "playwright:codegen": "NODE_ENV=development npx playwright codegen --target=html --output=./tests/playwright/demo.html --",
    "playwright:ci": "NODE_ENV=ci npx playwright test -c ./tests/playwright.config.ts --workers=1 test --project=ci",
    "playwright": "npx playwright",
    "sleep": "sleep infinity"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@pinia/nuxt": "^0.5.1",
    "ace-builds": "^1.36.2",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mitt": "^3.0.1",
    "nuxt": "^3.11.2",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^4.0.2",
    "sass": "^1.77.2",
    "vite-plugin-vuetify": "^2.0.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue3-ace-editor": "^2.2.4",
    "vuetify": "^3.6.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}
