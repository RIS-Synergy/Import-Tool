{
  "openapi": "3.0.1",
  "info": {
    "title": "Funding Api",
    "description": "### Ids for Example Fundings:\n\n> ***Call:*** AAUFUND1234\n>\n> ***Programme:*** AAUFUND1235",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://cris-staging.aau.at/ris-synergy/funding"
    }
  ],
  "tags": [
    {
      "name": "Fundings",
      "description": "In the RIS-Synergy Network, the Endpoints for fetching a list of Programmes and Calls or a single Programme or Call are provided by the RIS-APP \"Eingabetool\". The Endpoint for fetching a single Entity of the other Funding Types which describes the contract for a project are only provided by the funders."
    }
  ],
  "paths": {
    "/v1/fundings": {
      "get": {
        "tags": [
          "Fundings"
        ],
        "summary": "GET Endpoint for Fundings",
        "description": "Get Endpoint for retrieving all Fundings",
        "operationId": "findAll",
        "parameters": [
          {
            "name": "fundingType",
            "in": "query",
            "description": "\tNach spezifischen Typ gefilterte Fundings abfragen\nVocabulary: [Eligible Applicants Scope - Vocabulary](https://documentation.forschungsdaten.at/?page_id=303)",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/FundingType"
            }
          },
          {
            "name": "targetGroup",
            "in": "query",
            "description": "\tNach spezifischen Zielgruppen (Organisationstypen) gefilterte Calls abfragen\nVocabulary: [Target group - Vocabulary](https://documentation.forschungsdaten.at/?page_id=322)",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/TargetGroup"
            }
          },
          {
            "name": "runningCalls",
            "in": "query",
            "description": "\tDeadline der (ersten) Call-Stage liegt in der Zukunft (Feld: Call stage start 1)\n\tOngoing Call: Deadline = fiktives Datum in der Zukunft\n\tBeginndatum liegt in der Vergangenheit oder in der Gegenwart + Enddatum in der Zukunft oder ist nicht eingetragen",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "region",
            "in": "query",
            "description": "\tBundeslandspezifische Calls abfragen\nVocabulary: [Eligible Applicants Region - Vocabulary](https://documentation.forschungsdaten.at/?page_id=346)",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/EligibleApplicantsRegion"
            }
          },
          {
            "name": "funderId",
            "in": "query",
            "description": "\tCalls eines Fördergebers abfragen: Fördergeber ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "applicantsScope",
            "in": "query",
            "description": "\tNationale oder internationale Calls abfragen\nVocabulary: [Eligible Applicants Scope - Vocabulary](https://documentation.forschungsdaten.at/?page_id=343)",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/EligibleApplicantsScope"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Funding"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fundings/{id}": {
      "get": {
        "tags": [
          "Fundings"
        ],
        "summary": "GET Endpoint for Funding",
        "description": "Get Endpoint for retrieving Funding via ID",
        "operationId": "findByKey",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Funding"
                }
              }
            }
          }
        }
      }
    }
  },
